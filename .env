# Spotfire Copilot 백엔드 환경 변수 (Ollama + Redis 구성)
# 참고: "Getting Started with Spotfire Copilot - Backend Infrastructure Setup" Appendix

LOG_LEVEL=INFO

# JWT 토큰 서명용 시크릿 키 (openssl rand -hex 32 로 생성)
SECRET_KEY=88f98bc993557c2452602126f6365bd3e8967520103ee01d0eb01a216a46c295

# admin 계정의 bcrypt 해시 비밀번호. 현재 값은 "admin1234" 의 해시 — 반드시 본인 비밀번호로 교체하세요!
# (https://bcrypt-generator.com/ 에서 생성)
# 주의: docker compose 가 "$" 를 변수로 해석하므로 해시 안의 "$" 는 모두 "$$" 로 바꿔야 함 (PDF 17p)
HASHED_ADMIN_PASSWORD=$$2b$$12$$zM6hKGJVMyH2BxMgW0zAsO1rxVCXCEZomQKJNIj/ZdpDOdTvpGtmC

ACCESS_TOKEN_EXPIRE_DAYS=7

# Data Loader 에 마운트할 PDF 문서 폴더 (호스트 경로)
DOCS_DIR=./docs

# ── Plugins ─────────────────────────────────────────────
# Data Loader 용
VECTORDB_PLUGIN_ENTRY_POINT=plugins.vectordbs.redis:RedisRetrieverPlugin
# Orchestrator 용
RETRIEVER_PLUGIN_ENTRY_POINT=plugins.retrievers.redis:RedisRetrieverPlugin
# 공통 (LLM / Embedding = Ollama)
MODEL_PLUGIN_ENTRY_POINT=plugins.models.ollama:OllamaPlugin
SECONDARY_MODEL_PLUGIN_ENTRY_POINT=plugins.models.ollama:OllamaPlugin
EMBEDDINGS_PLUGIN_ENTRY_POINT=plugins.embeddings.ollama:OllamaEmbeddingsPlugin

# ── Models ──────────────────────────────────────────────
# 호스트 PC 의 Ollama 에 미리 받아둔 모델명과 일치해야 함 (ollama list 로 확인)
# 예: ollama pull llama3.1 / ollama pull nomic-embed-text
MODEL_NAME=llama3.1
EMBEDDING_MODEL_NAME=nomic-embed-text
MULTI_MODAL_MODEL_NAME=llama3.1
COMPLETIONS_MODEL_NAME=llama3.1
CHAT_SIMPLE_MODEL_NAME=llama3.1
CHAT_COMPLEX_MODEL_NAME=llama3.1

# ── Ollama ──────────────────────────────────────────────
# 컨테이너에서 호스트 PC 의 Ollama(11434 포트)로 접근
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── VectorDB (Redis) ────────────────────────────────────
# 같은 docker 네트워크 안의 redis 서비스명으로 접근
REDIS_URL=redis://redis:6379/0

# ── Optional monitoring (Langsmith) ─────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=
LANGCHAIN_PROJECT=
